# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (Supabase PostgreSQL direct connection) ───
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Gemini (at least one key required) ───
GEMINI_API_KEY=
# YUNWU_GEMINI_API_KEY=
# YUNWU_API_KEY=
GEMINI_BASE_URL=https://yunwu.ai

# ─── Video Provider (Sora/VEO via BLTCY) ───
VIDEO_API_KEY=
VIDEO_BASE_URL=https://api.bltcy.ai
# VIDEO_MODEL=veo3.1-fast
# VIDEO_HD=false

# ─── TikHub (抖音/TikTok link parsing) ───
TIKHUB_API_KEY=

# ─── Cloudflare R2 Upload Gateway ───
UPLOAD_API_URL=
UPLOAD_API_KEY=
UPLOAD_PREFIX=vidclaw-assets
