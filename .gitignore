# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tool state — never commit
/.claude/
/.playwright-mcp/

# SEO / one-off verification screenshots captured at repo root
# (don't touch anything under src/ or docs/ — this is for ad-hoc screenshots
#  engineers drop while verifying Search Console / Bing Webmaster / 百度站长 / etc.)
/baidu-*.png
/bing-*.png
/gsc-*.png
/yandex-*.png
/pricing-after.png
